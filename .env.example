# ============================================
# VSUAL Business OS - Environment Variables
# ============================================
# Copy this file to .env.local for local development
# On Vercel: add these in Project Settings > Environment Variables

# Direct Postgres URL — Prisma CLI (migrate, db push) reads this via prisma.config.ts
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Optional: Prisma Accelerate (prisma+postgres://…?api_key=…). When set, the app uses it for PrismaClient; keep DATABASE_URL direct for migrations.
# PRISMA_ACCELERATE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=..."

# NextAuth
NEXTAUTH_SECRET="generate-a-random-32-char-string"
NEXTAUTH_URL="https://your-vercel-domain.vercel.app"

# Vercel CLI / REST API (token from Dashboard → Settings → Tokens; prefix vcp_)
# VERCEL_TOKEN="vcp_..."

# Optional: AI — priority: 1) Hugging Face router  2) OpenRouter  3) Z AI (.z-ai-config)
# HF_TOKEN="hf_..."  # https://huggingface.co/settings/tokens
# HF_ROUTER_BASE_URL="https://router.huggingface.co/v1"
# HF_CHAT_MODEL="moonshotai/Kimi-K2-Instruct-0905"
#
# Hugging Face CLI (bucket sync): install Python 3.10+ on PATH, then npm run hf:install, then hf:sync:up / hf:sync:down
#
# Z_AI_BASE_URL="https://openrouter.ai/api/v1"
# Z_AI_API_KEY="sk-or-v1-..."
# Z_AI_MODEL="openai/gpt-4o-mini"
# OPENROUTER_HTTP_REFERER="https://your-production-domain.com"
