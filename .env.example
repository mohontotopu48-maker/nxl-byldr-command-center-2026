# ============================================
# VSUAL Business OS - Environment Variables
# ============================================
# Copy this file to .env.local for local development
# On Vercel: add these in Project Settings > Environment Variables

# Database (PostgreSQL connection string)
# Get one free from: https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-32-char-string"
NEXTAUTH_URL="https://your-vercel-domain.vercel.app"

# Optional: AI (z-ai-web-dev-sdk)
# Z_AI_API_KEY="your-api-key"
