# ============================================
# VSUAL NXL BYLDR Command Center - Environment Variables
# ============================================
# Copy this file to .env.local for local development.
# On Vercel: add these in Project Settings > Environment Variables.
# ALL starred (*) variables are REQUIRED for deployment.

# * PostgreSQL connection string — Prisma CLI (migrate, db push) reads this via prisma.config.ts
#   Must include ?sslmode=require for Vercel/Neon/Supabase
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# * NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-32-char-string"

# * NextAuth URL — set to your Vercel deployment URL
NEXTAUTH_URL="https://your-app.vercel.app"

# Optional: Prisma Accelerate (prisma+postgres://…?api_key=…)
# When set, the app uses it for PrismaClient; keep DATABASE_URL for migrations.
# PRISMA_ACCELERATE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=..."

# Optional: AI providers — priority: 1) Hugging Face  2) OpenRouter  3) Z AI SDK (built-in)
# HF_TOKEN="hf_..."
# HF_ROUTER_BASE_URL="https://router.huggingface.co/v1"
# HF_CHAT_MODEL="moonshotai/Kimi-K2-Instruct-0905"
#
# Z_AI_API_KEY="sk-or-v1-..."
# Z_AI_BASE_URL="https://openrouter.ai/api/v1"
# Z_AI_MODEL="openai/gpt-4o-mini"
# OPENROUTER_HTTP_REFERER="https://your-production-domain.com"
