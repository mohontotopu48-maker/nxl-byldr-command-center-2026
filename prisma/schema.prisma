generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(active)
  priority    TaskPriority  @default(medium)
  progress    Int           @default(0)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tasks       Task[]

  @@index([status])
}

model Task {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      TaskStatus    @default(pending)
  priority    TaskPriority  @default(medium)
  projectId   String
  assigneeId  String?
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    TeamMember?   @relation(fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

model TeamMember {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String     @default("")
  role      UserRole   @default(member)
  avatar    String?
  status    UserStatus @default(active)
  phone     String?
  location  String?
  bio       String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tasks     Task[]

  @@index([role])
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  message   String
  userId    String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model Metric {
  id         String   @id @default(cuid())
  name       String
  value      Float
  unit       String?
  category   String
  recordedAt DateTime @default(now())

  @@index([category])
  @@index([recordedAt])
}

model Customer {
  id          String          @id @default(cuid())
  name        String
  email       String          @unique
  password    String          @default("")
  company     String?
  phone       String?
  status      CustomerStatus  @default(active)
  plan        CustomerPlan    @default(free)
  revenue     Float           @default(0)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  journeys    ClientJourney[]

  @@index([status])
  @@index([plan])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model SetupStep {
  id          String       @id @default(cuid())
  stepNumber  Int          @unique
  title       String
  description String?
  phase       JourneyPhase @default(discovery)
  status      String       @default("pending")
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AlertBar {
  id        String   @id @default(cuid())
  active    Boolean  @default(false)
  message   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/* ═══════════════════════════════════════════════════════════════ */
/*  Per-Client Customer Journey Models                             */
/* ═══════════════════════════════════════════════════════════════ */

model ClientJourney {
  id              String           @id @default(cuid())
  customerId      String
  currentPhase    JourneyPhase     @default(discovery)
  overallStatus   JourneyStatus    @default(active)
  completedSteps  Int              @default(0)
  totalSteps      Int              @default(13)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  setupSteps      ClientSetupStep[]
  alerts          ClientAlert[]
  automationLogs  AutomationLog[]

  @@unique([customerId])
  @@index([currentPhase])
  @@index([overallStatus])
}

model ClientSetupStep {
  id          String       @id @default(cuid())
  journeyId   String
  stepNumber  Int
  title       String
  description String?
  phase       JourneyPhase @default(discovery)
  status      String       @default("pending")
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  journey     ClientJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([journeyId, stepNumber])
  @@index([journeyId])
  @@index([phase])
  @@index([status])
}

model ClientAlert {
  id        String   @id @default(cuid())
  journeyId String
  active    Boolean  @default(false)
  message   String   @default("")
  priority  String   @default("normal")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  journey   ClientJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([journeyId])
}

model AutomationLog {
  id         String   @id @default(cuid())
  journeyId  String
  action     String
  details    String?
  triggeredBy String  @default("manual")
  createdAt  DateTime @default(now())
  journey    ClientJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([journeyId])
}

/* ═══════════════════════════════════════════════════════════════ */
/*  MPZ Models (kept as-is)                                       */
/* ═══════════════════════════════════════════════════════════════ */

model MpzLead {
  id                 String       @id @default(cuid())
  name               String
  businessName       String
  phone              String
  email              String       @unique
  serviceType        String
  stage              MpzLeadStage @default(new_lead)
  assignedTo         String       @default("Sal")
  tags               String       @default("CA_BYLDR_LEAD")
  mockupReady        Boolean      @default(false)
  automationStarted  Boolean      @default(false)
  automationDay      Int          @default(0)
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  tasks              MpzTask[]
  activities         MpzActivity[]

  @@index([stage])
  @@index([createdAt(sort: Desc)])
  @@index([assignedTo])
}

model MpzTask {
  id          String          @id @default(cuid())
  title       String
  description String?
  status      MpzTaskStatus   @default(pending)
  priority    MpzTaskPriority @default(medium)
  assignedTo  String
  leadId      String?
  dueDate     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lead        MpzLead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([status])
  @@index([assignedTo])
}

model MpzActivity {
  id        String   @id @default(cuid())
  type      String
  message   String
  leadId    String?
  createdAt DateTime @default(now())
  lead      MpzLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([createdAt(sort: Desc)])
}

/* ═══════════════════════════════════════════════════════════════ */
/*  Customer Portal & Contact Models                                */
/* ═══════════════════════════════════════════════════════════════ */

model ContactMessage {
  id           String        @id @default(cuid())
  customerName String
  customerEmail String
  subject      String
  message      String
  priority     String        @default("normal")
  status       ContactStatus @default(new)
  assignedTo   String        @default("both")
  reply        String?
  repliedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([customerEmail])
  @@index([status])
}

/* ═══════════════════════════════════════════════════════════════ */
/*  Enums                                                         */
/* ═══════════════════════════════════════════════════════════════ */

enum ProjectStatus {
  active
  completed
  paused
  archived
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  critical
}

enum UserStatus {
  active
  inactive
  suspended
}

enum UserRole {
  master_admin
  admin
  manager
  member
}

enum CustomerPlan {
  free
  pro
  enterprise
}

enum CustomerStatus {
  active
  inactive
}

enum JourneyPhase {
  discovery
  strategy
  delivery
  launch
  growth
}

enum JourneyStatus {
  active
  completed
  paused
  on_hold
}

enum MpzLeadStage {
  new_lead
  mockup_needed
  mockup_sent
  engaged
  video_sent
  proof_stage
  hot_lead
  call_scheduled
  closed_won
  closed_lost
  retention
  contacted
  qualified
  proposal_sent
  mockup_ready
  mockup_delivered
  revision
}

enum MpzTaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum MpzTaskPriority {
  low
  medium
  high
  urgent
}

enum ContactStatus {
  new
  in_progress
  replied
  closed
  spam
}
