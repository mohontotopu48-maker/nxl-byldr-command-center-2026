generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("active")
  priority    String   @default("medium")
  progress    Int      @default(0)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      String     @default("todo")
  priority    String     @default("medium")
  projectId   String
  assigneeId  String?
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    TeamMember? @relation(fields: [assigneeId], references: [id])
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   @default("")
  role      String   @default("member")
  avatar    String?
  status    String   @default("active")
  phone     String?
  location  String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model Activity {
  id        String   @id @default(cuid())
  type      String
  message   String
  userId    String?
  metadata  String?
  createdAt DateTime @default(now())
}

model Metric {
  id         String   @id @default(cuid())
  name       String
  value      Float
  unit       String?
  category   String
  recordedAt DateTime @default(now())
}

model Customer {
  id          String          @id @default(cuid())
  name        String
  email       String          @unique
  password    String          @default("")
  company     String?
  phone       String?
  status      String          @default("active")
  plan        String          @default("free")
  revenue     Float           @default(0)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  journeys    ClientJourney[]
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SetupStep {
  id          String    @id @default(cuid())
  stepNumber  Int       @unique
  title       String
  description String?
  phase       String    @default("handover")
  status      String    @default("pending")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AlertBar {
  id        String   @id @default(cuid())
  active    Boolean  @default(false)
  message   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/* ═══════════════════════════════════════════════════════════════ */
/*  Per-Client Customer Journey Models                             */
/* ═══════════════════════════════════════════════════════════════ */

model ClientJourney {
  id              String           @id @default(cuid())
  customerId      String
  currentPhase    String           @default("handover")
  overallStatus   String           @default("in_progress")
  completedSteps  Int              @default(0)
  totalSteps      Int              @default(13)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  setupSteps      ClientSetupStep[]
  alerts          ClientAlert[]
  automationLogs  AutomationLog[]
}

model ClientSetupStep {
  id          String   @id @default(cuid())
  journeyId   String
  stepNumber  Int
  title       String
  description String?
  phase       String   @default("handover")
  status      String   @default("pending")
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  journey     ClientJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
}

model ClientAlert {
  id        String   @id @default(cuid())
  journeyId String
  active    Boolean  @default(false)
  message   String   @default("")
  priority  String   @default("normal")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  journey   ClientJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
}

model AutomationLog {
  id         String   @id @default(cuid())
  journeyId  String
  action     String
  details    String?
  triggeredBy String  @default("manual")
  createdAt  DateTime @default(now())
  journey    ClientJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
}

/* ═══════════════════════════════════════════════════════════════ */
/*  MPZ Models (kept as-is)                                       */
/* ═══════════════════════════════════════════════════════════════ */

model MpzLead {
  id                 String   @id @default(cuid())
  name               String
  businessName       String
  phone              String
  email              String
  serviceType        String
  stage              String   @default("new_lead")
  assignedTo         String   @default("Sal")
  tags               String   @default("CA_BYLDR_LEAD")
  mockupReady        Boolean  @default(false)
  automationStarted  Boolean  @default(false)
  automationDay      Int      @default(0)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tasks              MpzTask[]
  activities         MpzActivity[]
}

model MpzTask {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pending")
  priority    String    @default("medium")
  assignedTo  String
  leadId      String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lead        MpzLead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model MpzActivity {
  id        String   @id @default(cuid())
  type      String
  message   String
  leadId    String?
  createdAt DateTime @default(now())
  lead      MpzLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

/* ═══════════════════════════════════════════════════════════════ */
/*  Customer Portal & Contact Models                                */
/* ═══════════════════════════════════════════════════════════════ */

model ContactMessage {
  id          String   @id @default(cuid())
  customerName String
  customerEmail String
  subject     String
  message     String
  priority    String   @default("normal")
  status      String   @default("unread")
  assignedTo  String   @default("both")
  reply       String?
  repliedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
